shamefully-hoist=true
strict-peer-dependencies=false
ignore-scripts=true
# Required by MiniPay's current Mini App submission docs (dependency
# security section): block installing any dependency version published
# less than 7 days ago, so a freshly-published supply-chain-attack release
# can't slip in even with a lockfile, if the lockfile is ever regenerated.
# Supported by pnpm v10.16+ and npm v11+; older versions ignore this key
# rather than erroring.
minimum-release-age=10080
